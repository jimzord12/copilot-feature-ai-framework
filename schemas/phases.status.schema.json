{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phases Status",
  "type": "array",
  "items": { "$ref": "#/definitions/Phase" },
  "definitions": {
    "Task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "A stable identifier for the task."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "The human-readable task name."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\.md$",
          "description": "Relative path from the containing feature or epic root to the task markdown file."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "A short summary used to select and understand the task before opening its file."
        },
        "status": {
          "type": "string",
          "description": "The current progress of the task.",
          "enum": ["not-started", "in-progress", "completed"]
        }
      },
      "required": ["id", "name", "path", "summary", "status"]
    },
    "Phase": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "A stable identifier for the phase."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "The human-readable phase name."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path from the containing feature or epic root to the phase folder."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "A short summary used to choose the phase before opening its markdown file."
        },
        "status": {
          "type": "string",
          "description": "The current progress of the phase.",
          "enum": ["not-started", "tasks-generated", "in-progress", "completed"]
        },
        "tasks": {
          "type": "array",
          "description": "Machine-friendly phase task state entries.",
          "items": { "$ref": "#/definitions/Task" }
        }
      },
      "required": ["id", "name", "path", "summary", "status", "tasks"]
    }
  }
}
