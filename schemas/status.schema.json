{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Phase"
  },
  "definitions": {
    "Phase": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of this phase of the project."
        },
        "status": {
          "type": "string",
          "description": "The current progress of this phase.",
          "enum": ["todo", "in-progress", "done"]
        }
      },
      "required": ["name", "status"]
    }
  }
}
