{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Epics Status",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Epic"
  },
  "definitions": {
    "Epic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "A stable identifier for the epic."
        },
        "name": {
          "type": "string",
          "description": "The human-readable epic name."
        },
        "path": {
          "type": "string",
          "description": "Relative path from the containing feature root to the epic folder."
        },
        "status": {
          "type": "string",
          "description": "The current progress of the epic.",
          "enum": ["not-started", "in-progress", "completed"]
        }
      },
      "required": ["id", "name", "path", "status"]
    }
  }
}